# ── Credentials ────────────────────────────────────────────
# Copy this file to .env and fill in your values
OGAME_EMAIL=your@email.com
OGAME_PASSWORD=yourpassword

# ── Server ─────────────────────────────────────────────────
# Your OGame server URL (change to match your universe)
OGAME_SERVER=https://s261-pl.ogame.gameforge.com

# ── Browser ────────────────────────────────────────────────
# Set to false to watch the browser in action (useful for debugging)
HEADLESS=true

# ── Agent behaviour ────────────────────────────────────────
# How often to run a full cycle, in milliseconds (default: 5 min)
CYCLE_INTERVAL_MS=300000

# Comma-separated tactics in priority order
ACTIVE_TACTICS=economics,defense,collector,attacker

# Active hours window (Warsaw / server time, 24h). Agent sleeps outside this window.
# Example: 7–3 means active from 07:00 to 03:00 the next day (overnight)
ACTIVE_HOURS_START=7
ACTIVE_HOURS_END=3

# ── Session ────────────────────────────────────────────────
SESSION_FILE=./session.json
LOG_LEVEL=info

# Disable the interactive TUI and use plain console output instead
# NO_TUI=true

# ── Attacker safety ────────────────────────────────────────
# Minimum defense score on target planet before attacking (0 = no limit)
DEFENSE_SAFE_THRESHOLD=5000
# Minimum espionage tech level required before sending probes
ESPIONAGE_MIN_LEVEL=5

# ── Attacker scanning strategy ─────────────────────────────
# Scan mode: "standard" (deterministic radius from home) or "random" (stochastic spread)
ATTACK_SCAN_MODE=standard
# Standard mode: ±N systems around home planet for target discovery
ATTACK_PROBE_RANGE=4
# Random mode: number of random system picks per cycle, and max distance to scan in range
ATTACK_RANDOM_SYSTEMS_RANGE="6,500"  # format: "MAX_PICKS,MAX_DISTANCE"

# ── Model Config ───────────────────────────────────────────
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://oai.endpoints.kepler.ai.cloud.ovh.net/v1
# Model name — must support JSON mode
OPENAI_MODEL=Qwen2.5-VL-72B-Instruct

# How many cycles to cache the AI strategic plan before refreshing (saves tokens)
AI_REFRESH_CYCLES=3
